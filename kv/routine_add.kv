<RoutineAddScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: app.bg_color
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: .10
            canvas.before:
                Color:
                    rgba: app.header_color
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: 'Routine'
                color: app.text_color
                bold: True
                font_size: '32sp'

        BoxLayout:
            orientation: 'vertical'
            padding: [12, 40, 12, 40]
            spacing: 24

            BoxLayout:
                orientation: 'vertical'
                padding: [32, 24, 32, 24]
                spacing: 20
                canvas.before:
                    Color:
                        rgba: app.card_color
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [16]

                Label:
                    text: 'Add Task'
                    color: app.text_color
                    bold: True
                    font_size: '30sp'
                    size_hint_y: .14
                    halign: 'left'
                    text_size: self.size

                Label:
                    text: 'Task Type'
                    color: app.text_color
                    bold: True
                    font_size: '20sp'
                    size_hint_y: .08
                    halign: 'left'
                    text_size: self.size

                GridLayout:
                    cols: 2
                    size_hint_y: .22
                    spacing: 8
                    BoxLayout:
                        CheckBox:
                            id: cat_class
                            group: 'task_cat'
                            active: True
                        Label:
                            text: 'Class'
                            color: app.text_color
                    BoxLayout:
                        CheckBox:
                            id: cat_study
                            group: 'task_cat'
                        Label:
                            text: 'Study'
                            color: app.text_color
                    BoxLayout:
                        CheckBox:
                            id: cat_work
                            group: 'task_cat'
                        Label:
                            text: 'Work'
                            color: app.text_color
                    BoxLayout:
                        CheckBox:
                            id: cat_other
                            group: 'task_cat'
                        Label:
                            text: 'Other'
                            color: app.text_color

                TextInput:
                    id: task_title
                    hint_text: 'Enter Task'
                    multiline: False
                    background_color: (1,1,1,1)
                    foreground_color: app.text_color
                    hint_text_color: app.muted_text_color
                    font_size: '22sp'
                    size_hint_y: .14

                Widget:

                BoxLayout:
                    size_hint_y: .14
                    spacing: 16
                    Button:
                        text: 'Confirm'
                        background_normal: ''
                        background_color: app.header_color
                        color: app.text_color
                        bold: True
                        font_size: '22sp'
                        on_release: root.confirm()
                    Button:
                        text: 'Cancel'
                        background_normal: ''
                        background_color: app.header_color
                        color: app.text_color
                        bold: True
                        font_size: '22sp'
                        on_release: root.cancel()
